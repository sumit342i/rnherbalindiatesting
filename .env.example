# Email Configuration
# This file contains sensitive information - NEVER commit .env to git!
# Copy this file to .env and fill in your actual credentials

# Gmail sender email address (the email that will send order confirmations)
EMAIL_USER=your-gmail-email@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# See setup guide below on how to create this
EMAIL_PASSWORD=your-16-character-app-password

# Admin email address (where order notifications are sent)
# If not set, defaults to 'support@rnherbalindia.com'
ADMIN_EMAIL=your-admin-email@gmail.com

# Server Configuration
PORT=5000
NODE_ENV=development

# IMPORTANT: How to get Gmail App Password
# =========================================
# 1. Go to myaccount.google.com
# 2. Click "Security" in the left menu
# 3. Enable "2-Step Verification" (if not already enabled)
# 4. After 2FA is enabled, go back to Security
# 5. Find "App passwords" option (appears only after 2FA is enabled)
# 6. Select "Mail" and "Windows Computer" (or your device)
# 7. Google will generate a 16-character password
# 8. Copy that password to EMAIL_PASSWORD above
# 9. Remove spaces from the app password if any
